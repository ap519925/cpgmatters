{#
/**
 * @file
 * Theme override for the registration webform.
 * 
 * We wrap the webform inside the EXACT wrapper markup used by the old custom
 * CPG module to ensure exact style parity without CSS changes.
 */
#}
<div class="cpg-register-wrapper wrapper-page page-register-step1 page-register-step2" style="background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px; width: 100%; margin: 0; box-sizing: border-box; flex-direction: column;">
  <div class="registration-container" style="width: 100%; max-width: 600px; margin: 0 auto; box-sizing: border-box;">
    <form{{ attributes }}>
      {{ title_prefix }}
      {{ children }}
      {{ title_suffix }}
    </form>
  </div>
</div>
