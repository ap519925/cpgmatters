{#
/**
 * @file
 * Paragraph template: Hero Banner (cpg_hero)
 * Fields: field_p_title, field_p_subtitle, field_p_image, field_p_link
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    'cpg-paragraph-hero',
  ]
%}
{% block paragraph %}
  <section{{ attributes.addClass(classes) }}>
    {% if content.field_p_image|render|trim %}
      <div class="cpg-paragraph-hero__bg">
        {{ content.field_p_image }}
      </div>
    {% endif %}
    <div class="cpg-paragraph-hero__overlay"></div>
    <div class="cpg-paragraph-hero__content">
      {% if content.field_p_title|render|striptags|trim %}
        <h1 class="cpg-paragraph-hero__title">{{ content.field_p_title }}</h1>
      {% endif %}
      {% if content.field_p_subtitle|render|trim %}
        <div class="cpg-paragraph-hero__subtitle">{{ content.field_p_subtitle }}</div>
      {% endif %}
      {% if content.field_p_link|render|trim %}
        <div class="cpg-paragraph-hero__cta">{{ content.field_p_link }}</div>
      {% endif %}
    </div>
  </section>
{% endblock paragraph %}
