{#
/**
 * @file
 * Paragraph template: Blockquote / Testimonial (cpg_quote)
 * Fields: field_p_body (quote), field_p_title (attribution), field_p_icon (role), field_p_image (photo)
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    'cpg-paragraph-quote',
  ]
%}
{% block paragraph %}
  <blockquote{{ attributes.addClass(classes) }}>
    <div class="cpg-paragraph-quote__mark" aria-hidden="true">&ldquo;</div>
    {% if content.field_p_body|render|trim %}
      <div class="cpg-paragraph-quote__text">{{ content.field_p_body }}</div>
    {% endif %}
    <footer class="cpg-paragraph-quote__footer">
      {% if content.field_p_image|render|trim %}
        <div class="cpg-paragraph-quote__photo">{{ content.field_p_image }}</div>
      {% endif %}
      <div class="cpg-paragraph-quote__attribution">
        {% if content.field_p_title|render|striptags|trim %}
          <cite class="cpg-paragraph-quote__name">{{ content.field_p_title }}</cite>
        {% endif %}
        {% if content.field_p_icon|render|striptags|trim %}
          <span class="cpg-paragraph-quote__role">{{ content.field_p_icon }}</span>
        {% endif %}
      </div>
    </footer>
  </blockquote>
{% endblock paragraph %}
