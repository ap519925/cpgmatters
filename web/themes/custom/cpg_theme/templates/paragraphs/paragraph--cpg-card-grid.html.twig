{#
/**
 * @file
 * Paragraph template: Card Grid (cpg_card_grid)
 * Fields: field_p_title, field_p_subtitle, field_p_items (nested cpg_card)
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    'cpg-paragraph-card-grid',
  ]
%}
{% block paragraph %}
  <section{{ attributes.addClass(classes) }}>
    {% if content.field_p_title|render|striptags|trim %}
      <h2 class="cpg-paragraph-card-grid__title">{{ content.field_p_title }}</h2>
    {% endif %}
    {% if content.field_p_subtitle|render|trim %}
      <div class="cpg-paragraph-card-grid__subtitle">{{ content.field_p_subtitle }}</div>
    {% endif %}
    <div class="cpg-paragraph-card-grid__grid">
      {{ content.field_p_items }}
    </div>
  </section>
{% endblock paragraph %}
