{#
/**
 * @file
 * Theme override to display a single page for CPG Matters.
 * Hardcoded elements to match the exact mockup design perfectly.
 */
#}
<div class="cpg-layout">

  {# ===== HEADER ===== #}
  {% if page.header or page.header_search or page.primary_menu %}
    <header class="cpg-layout__header" role="banner">
      <div class="cpg-container header-inner" style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem;">
        
        {# Branding #}
        <div class="header-branding" style="flex: 0 0 auto;">
          <a href="/" style="text-decoration: none; display: block;">
            <h1 style="color: #C41E3A; font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 900; margin: 0; line-height: 1; display:flex; align-items:center;">
              <img src="/core/misc/icons/787878/cog.svg" alt="" style="height: 24px; margin-right: 8px; filter: invert(20%) sepia(87%) saturate(3015%) hue-rotate(339deg) brightness(85%) contrast(97%); display: none;">
              CPG Matters
            </h1>
            <div style="font-size: 0.55rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px; font-weight: 700;">
              A brand marketing magazine for the 21st century
            </div>
          </a>
        </div>

        {# Navigation #}
        <div class="header-nav" style="flex: 1 1 auto; text-align: center;">
          {{ page.primary_menu }}
        </div>

        {# Actions (Subscribe + Search) #}
        <div class="header-actions" style="display: flex; flex-direction: column; align-items: flex-end; gap: 8px;">
          <a href="/user/register" style="background: #C41E3A; color: #fff; padding: 0.4rem 1.2rem; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; text-decoration: none; border-radius: 4px; letter-spacing: 0.05em; line-height: 1;">Subscribe</a>
          
          <form action="/search/node" method="get" style="display: flex; align-items: center;">
            <input type="search" name="keys" placeholder="Search articles..." style="border: 1px solid #E5E7EB; border-right: none; padding: 0.4rem 0.75rem; font-size: 0.8rem; border-radius: 4px 0 0 4px; outline: none; width: 180px;">
            <button type="submit" style="background: #111827; color: #fff; border: 1px solid #111827; padding: 0.4rem 0.85rem; font-size: 0.8rem; font-weight: 700; border-radius: 0 4px 4px 0; cursor: pointer;">Search</button>
          </form>
        </div>

      </div>
    </header>
  {% endif %}

  {% if page.hero %}
    <section class="cpg-layout__hero cpg-container">
      {{ page.hero }}
    </section>
  {% endif %}

  {% if page.top_banner %}
    <div class="cpg-layout__ad cpg-container" style="padding: 2rem 0; text-align: center;">
      {{ page.top_banner }}
    </div>
  {% endif %}

  <main role="main" class="cpg-layout__main cpg-container">
    {% if page.breadcrumb %}
      {{ page.breadcrumb }}
    {% endif %}

    <div class="cpg-columns" style="display: grid; grid-template-columns: 220px 1fr 320px; gap: 0;">
      {% if page.sidebar_first %}
        <aside class="cpg-sidebar cpg-sidebar--first" role="complementary" style="border-right: 2px solid #C41E3A; padding-right: 1.5rem; padding-top: 1rem;">
          {{ page.sidebar_first }}
        </aside>
      {% endif %}

      <div class="cpg-content-main" style="padding: 0 2rem;">
        {{ page.content }}
      </div>

      {% if page.sidebar_second %}
        <aside class="cpg-sidebar cpg-sidebar--second" role="complementary" style="border-left: 2px solid #C41E3A; padding-left: 1.5rem; padding-top: 1rem;">
          {{ page.sidebar_second }}
        </aside>
      {% endif %}
    </div>
  </main>

  <footer class="cpg-layout__footer" role="contentinfo" style="background: #1A1A1A; color: #fff; padding-top: 3rem; margin-top: 4rem;">
    <div class="cpg-container footer-columns" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;">
      <div class="footer-col">{{ page.footer_first }}</div>
      <div class="footer-col">{{ page.footer_second }}</div>
      <div class="footer-col">{{ page.footer_third }}</div>
      <div class="footer-col">{{ page.footer_fourth }}</div>
    </div>
    
    {% if page.footer_bottom %}
      <div class="footer-bottom" style="margin-top: 3rem; padding: 1.5rem 0; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; color: #9CA3AF; font-size: 0.85rem;">
        <div class="cpg-container">
          {{ page.footer_bottom }}
        </div>
      </div>
    {% endif %}
  </footer>
</div>
