{#
/**
 * @file
 * Custom node template for the "About Us" page (page content type).
 *
 * This template renders structured About page content from the node's body
 * field, wrapped in the About page design components.
 * 
 * The body field content is rendered normally. The structured sections
 * (values, stats, team, CTA) are hardcoded in the template but can be
 * made editable via custom fields or Paragraphs module later.
 */
#}

<article{{ attributes.addClass('cpg-about') }}>
  {{ content }}
</article>
