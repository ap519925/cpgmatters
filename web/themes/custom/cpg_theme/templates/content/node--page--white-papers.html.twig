{#
/**
 * @file
 * Custom node template for the "White Papers & Research" page.
 *
 * Renders structured content via Paragraphs, applying the original
 * cpg-whitepapers__* CSS classes for the exact same styling as before.
 */
#}

<article{{ attributes.addClass('cpg-whitepapers') }}>
  {% if content.field_cpg_paragraphs|render|trim %}
    {% for item in node.field_cpg_paragraphs %}
      {% set p = item.entity %}
      {% set ptype = p.bundle() %}

      {% if ptype == 'cpg_hero' %}
        {# ── Hero Section ── #}
        <section class="cpg-whitepapers__hero">
          <h1 class="cpg-whitepapers__title">{{ p.field_p_title.value }}</h1>
          {% if p.field_p_subtitle.value %}
            <p class="cpg-whitepapers__subtitle">{{ p.field_p_subtitle.value|striptags }}</p>
          {% endif %}
        </section>

      {% elseif ptype == 'cpg_text' %}
        {# ── Text Section ── #}
        <section class="cpg-about__section">
          <div class="cpg-about__text">
            {{ p.field_p_body.value|raw }}
          </div>
        </section>

      {% elseif ptype == 'cpg_card_grid' %}
        {# ── White Papers Grid ── #}
        <section class="cpg-whitepapers__popular">
          {% if p.field_p_title.value %}
            <div class="cpg-whitepapers__section-header">
              <h2>{{ p.field_p_title.value }}</h2>
            </div>
          {% endif %}
          <div class="cpg-whitepapers__grid">
            {% for card_item in p.field_p_items %}
              {% set card = card_item.entity %}
              <div class="wp-card">
                {% if card.field_p_image.entity %}
                  <div class="wp-card__image">
                    <img src="{{ file_url(card.field_p_image.entity.fileuri) }}" alt="{{ card.field_p_image.alt }}" />
                  </div>
                {% else %}
                  <div class="wp-card__image">
                    <span class="img-placeholder">📄</span>
                  </div>
                {% endif %}
                <div class="wp-card__content">
                  {% if card.field_p_icon.value %}
                    <div class="wp-card__category">{{ card.field_p_icon.value }}</div>
                  {% endif %}
                  <h3 class="wp-card__title">{{ card.field_p_title.value }}</h3>
                  {% if card.field_p_body.value %}
                    <p class="wp-card__excerpt">{{ card.field_p_body.value|striptags }}</p>
                  {% endif %}
                  {% if card.field_p_link.0.url %}
                    <div class="wp-card__footer">
                      <a href="{{ card.field_p_link.0.url }}" class="btn--red">{{ card.field_p_link.0.title|default('Download') }}</a>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        </section>

      {% elseif ptype == 'cpg_features' %}
        {# ── Topics Grid ── #}
        <section class="cpg-whitepapers__topics">
          {% if p.field_p_title.value %}
            <div class="cpg-whitepapers__section-header">
              <h2>{{ p.field_p_title.value }}</h2>
            </div>
          {% endif %}
          <div class="cpg-whitepapers__topics-grid">
            {% for topic_item in p.field_p_items %}
              {% set topic = topic_item.entity %}
              <a href="#" class="cpg-wp-topic-card">
                {% if topic.field_p_icon.value %}
                  <span class="topic-icon">{{ topic.field_p_icon.value }}</span>
                {% endif %}
                <h3>{{ topic.field_p_title.value }}</h3>
                {% if topic.field_p_body.value %}
                  <span class="topic-count">{{ topic.field_p_body.value|striptags }}</span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </section>

      {% elseif ptype == 'cpg_cta' %}
        {# ── CTA / Newsletter ── #}
        <section class="cpg-whitepapers__newsletter">
          {% if p.field_p_title.value %}
            <h2>{{ p.field_p_title.value }}</h2>
          {% endif %}
          {% if p.field_p_body.value %}
            <p>{{ p.field_p_body.value|striptags }}</p>
          {% endif %}
          {% if p.field_p_link.0.url %}
            <a href="{{ p.field_p_link.0.url }}" class="btn--red" style="display:inline-block; padding: 0.8rem 2rem; border-radius: 6px; text-decoration:none; font-weight:700;">{{ p.field_p_link.0.title }}</a>
          {% endif %}
        </section>

      {% else %}
        {# Fallback: render through standard paragraph rendering #}
        {{ content.field_cpg_paragraphs[loop.index0] }}
      {% endif %}

    {% endfor %}
  {% endif %}

  {# Fallback: render body field if no paragraphs exist yet #}
  {% if content.body|render|trim and not content.field_cpg_paragraphs|render|trim %}
    <div class="cpg-whitepapers__body-fallback">
      {{ content.body }}
    </div>
  {% endif %}

  <div class="hidden">
    {{ content|without('field_cpg_paragraphs', 'body') }}
  </div>
</article>
