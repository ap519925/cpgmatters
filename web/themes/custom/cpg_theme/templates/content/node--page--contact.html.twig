{#
/**
 * @file
 * Custom node template for the "Contact" page.
 *
 * Renders the form on the left (hardcoded to exactly match the mockup) 
 * and the paragraph sidebar on the right.
 */
#}
<article{{ attributes.addClass('cpg-contact-page') }}>
  <div class="cpg-contact-page__grid">
    
    {# Left Column: The Form #}
    <div class="cpg-contact-page__form-section cpg-about__text">
      <h1 class="page-title">Get in Touch</h1>
      <p class="intro-text">Have a question, feedback, or story idea? We'd love to hear from you. Fill out the form below and our team will get back to you within 24 hours.</p>
      
      <form class="cpg-contact-form" action="#" method="post">
        <div class="form-row">
          <div class="form-group">
            <label for="first-name">First Name <span class="required">*</span></label>
            <input type="text" id="first-name" required />
          </div>
          <div class="form-group">
            <label for="last-name">Last Name <span class="required">*</span></label>
            <input type="text" id="last-name" required />
          </div>
        </div>
        
        <div class="form-group">
          <label for="email">Email Address <span class="required">*</span></label>
          <input type="email" id="email" required />
        </div>
        
        <div class="form-group">
          <label for="company">Company/Organization</label>
          <input type="text" id="company" />
        </div>
        
        <div class="form-group">
          <label for="subject">Subject <span class="required">*</span></label>
          <select id="subject" required>
            <option value="">Please select...</option>
            <option value="Editorial">Editorial</option>
            <option value="Advertising">Advertising</option>
            <option value="Support">Support</option>
            <option value="Other">Other</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="message">Message <span class="required">*</span></label>
          <textarea id="message" rows="6" required></textarea>
        </div>
        
        <div class="form-checkbox-group">
          <label class="custom-checkbox">
            <input type="checkbox" name="newsletter" />
            <span class="checkmark"></span>
            Yes, I'd like to receive CPG Matters newsletter and updates
          </label>
        </div>

        <div class="form-checkbox-group">
          <label class="custom-checkbox">
            <input type="checkbox" name="terms" required />
            <span class="checkmark"></span>
            I agree to the <a href="/privacy">Privacy Policy</a> and <a href="/terms">Terms of Service</a><span class="required">*</span>
          </label>
        </div>
        
        <p class="required-note"><em>* Required fields</em></p>
        
        <button type="submit" class="btn--red btn--submit">SEND MESSAGE</button>
      </form>
    </div>

    {# Right Column: Sidebar (from paragraph field) #}
    <div class="cpg-contact-page__sidebar-section cpg-about__text">
      {% if content.field_cpg_paragraphs|render|trim %}
        {{ content.field_cpg_paragraphs }}
      {% endif %}
    </div>

  </div>
  <div class="hidden">
    {{ content|without('field_cpg_paragraphs', 'body') }}
  </div>
</article>
