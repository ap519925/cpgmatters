{#
/**
 * @file
 * Template for individual directory listing rows (grid format).
 *
 * Iterates over each directory listing card.
 *
 * @see template_preprocess_views_view_unformatted()
 */
#}

{% for row in rows %}
  <div class="cpg-directory__card-wrapper">
    {{ row.content }}
  </div>
{% endfor %}
