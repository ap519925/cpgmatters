{#
/**
 * @file
 * Theme override to display a view of unformatted rows for the front page.
 */
#}
{% if title %}
  <h3>{{ title }}</h3>
{% endif %}
<div class="cpg-frontpage-articles">
  {% for row in rows %}
    {%
      set row_classes = [
        default_row_class ? 'views-row',
      ]
    %}
    <div{{ row.attributes.addClass(row_classes) }}>
      {{ row.content }}
    </div>
  {% endfor %}

  {# ── View All Articles Button ── #}
  <div class="cpg-view-more-container" style="text-align: center; margin-top: 3rem; margin-bottom: 3rem;">
    <a href="/articles" class="cpg-subscribe-btn" style="padding: 0.8rem 2.5rem; font-size: 1.05rem; border-radius: 50px; display: inline-block;">
      View All Articles
    </a>
  </div>
</div>
