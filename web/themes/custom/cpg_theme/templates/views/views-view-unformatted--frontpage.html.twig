{#
/**
 * @file
 * Theme override to display a view of unformatted rows for the front page.
 */
#}
{% if title %}
  <h3>{{ title }}</h3>
{% endif %}
<div class="cpg-frontpage-articles">
  {% for row in rows %}
    {%
      set row_classes = [
        default_row_class ? 'views-row',
      ]
    %}
    <div{{ row.attributes.addClass(row_classes) }}>
      {{ row.content }}
    </div>
  {% endfor %}


</div>
