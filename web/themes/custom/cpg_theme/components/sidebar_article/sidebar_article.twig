<article class="cpg-sidebar-article">
  <div class="cpg-sidebar-article__image">
    <img src="{{ image_url }}" alt="{{ title }}" />
  </div>
  <div class="cpg-sidebar-article__content">
    <span class="category-label" style="font-size: 0.65rem;">{{ category }}</span>
    <h4 class="cpg-sidebar-article__title">
      <a href="#" style="text-decoration: none; color: inherit;">{{ title }}</a>
    </h4>
    <div class="cpg-sidebar-article__body">{{ body }}</div>
  </div>
</article>
