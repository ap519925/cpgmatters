        'grouped_terms' => [],
        'available_letters' => [],
        'categories' => [],
        'total_count' => 0,
        'title' => NULL,
        'subtitle' => NULL,
      ],
      'template' => 'cpg-dictionary-page',
    ],
  ];
}

